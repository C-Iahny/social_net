# ── Dina ──
msgid "Dina"
msgstr "Dina"

msgid "Community Charter"
msgstr "Dina Iombonana"

msgid "Agreements, rules and traditions that govern this community."
msgstr "Fifanarahana, fitsipika ary fomban-drazana mifanapaka amin'ity vondrona ity."

msgid "No Dina defined yet for this group."
msgstr "Tsy misy Dina voafaritra mbola ho an'ity vondrona ity."

